{
    "name": "script-development/kendo-report-tool",
    "description": "Laravel client library that submits user reports into a kendo project's report endpoint.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "kendo",
        "feedback",
        "reports"
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ScriptDevelopment\\KendoReportTool\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScriptDevelopment\\KendoReportTool\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ScriptDevelopment\\KendoReportTool\\KendoReportToolServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=98",
        "phpstan": "phpstan analyse",
        "format": "pint",
        "format:check": "pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
